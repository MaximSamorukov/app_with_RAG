# ===========================================
# RAG Assistant - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# -------------------------------------------
# Application
# -------------------------------------------
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# -------------------------------------------
# Database (PostgreSQL 16 + pgvector)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5433
DB_NAME=rag_assistant
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# -------------------------------------------
# Redis (BullMQ 5.x)
# -------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# -------------------------------------------
# Object Storage (S3-compatible)
# -------------------------------------------
# For development, use MinIO or localstack
# For production, use AWS S3 or compatible service
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=rag-assistant-documents
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# -------------------------------------------
# AI Provider Configuration
# -------------------------------------------
# Supported providers: openai, anthropic
# Provider-agnostic design allows switching between providers
AI_PROVIDER=openai
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# For Anthropic provider:
# AI_PROVIDER=anthropic
# AI_API_KEY=your-anthropic-api-key
# AI_MODEL=claude-3-5-sonnet-20241022

# -------------------------------------------
# RAG Pipeline Configuration
# -------------------------------------------
# Vector search threshold (cosine similarity)
VECTOR_SEARCH_THRESHOLD=0.75
# Number of chunks to retrieve before reranking
VECTOR_SEARCH_TOP_K=20
# Number of chunks after reranking
RERANK_TOP_K=5
# Chunk size in characters
CHUNK_SIZE=1000
# Chunk overlap in characters
CHUNK_OVERLAP=200

# -------------------------------------------
# Chat Configuration
# -------------------------------------------
# Maximum messages per chat session
CHAT_MAX_MESSAGES=200
# Single active session per user
CHAT_SINGLE_SESSION=true

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# -------------------------------------------
# Logging
# -------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=dev

# -------------------------------------------
# Health Check
# -------------------------------------------
HEALTH_CHECK_ENABLED=true

# ===========================================
# Admin User (for initial setup)
# ===========================================
# First admin user created by db:seed script
# IMPORTANT: Change these values in production!
# DO NOT commit .env file to version control!

ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=ChangeMeInProduction123!

# Password requirements:
# - Minimum 8 characters
# - At least 1 uppercase letter (A-Z)
# - At least 1 digit (0-9)
