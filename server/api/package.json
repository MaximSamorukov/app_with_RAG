{
  "name": "@rag-assistant/api",
  "version": "1.0.0",
  "private": true,
  "description": "RAG Assistant API Server",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=\\\\.spec\\\\.ts$ --testPathIgnorePatterns=\\\\.integration\\\\.spec\\\\.ts$",
    "test:integration": "jest --testPathPattern=\\\\.integration\\\\.spec\\\\.ts$",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "migration:run": "tsx node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "migration:generate": "tsx node_modules/typeorm/cli.js migration:generate -d src/database/data-source.ts src/database/migrations/$npm_config_name",
    "migration:revert": "tsx node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
    "migration:create": "tsx node_modules/typeorm/cli.js migration:create src/database/migrations/$npm_config_name",
    "db:seed": "tsx ../scripts/seed-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.478.0",
    "@aws-sdk/s3-request-presigner": "^3.478.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.19",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@golevelup/ts-jest": "^3.0.0",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
